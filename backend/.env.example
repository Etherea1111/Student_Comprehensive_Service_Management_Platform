NODE_ENV=development
PORT=8080
API_BASE_PATH=/api

# Kingbase is PostgreSQL-compatible in common Node.js deployments.
DATABASE_URL=postgres://student_service:change_me@127.0.0.1:54321/student_service

JWT_SECRET=replace_with_a_long_random_secret
DATA_CRYPTO_KEY=replace_with_another_long_random_secret
INITIAL_STUDENT_PASSWORD=RUC@123456
WECHAT_APP_ID=replace_with_wechat_app_id
WECHAT_APP_SECRET=replace_with_wechat_app_secret

UPLOAD_DIR=uploads/files
MAX_UPLOAD_MB=30
CORS_ORIGIN=*
