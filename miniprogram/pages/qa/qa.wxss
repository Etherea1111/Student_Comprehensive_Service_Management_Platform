.search-panel {
  margin-top: 28rpx;
  padding: 22rpx;
}

.search-row {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  width: 100%;
  min-height: 76rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  background: #ffffff;
  color: #101828;
  font-size: 28rpx;
}

.search-button {
  width: 148rpx;
  margin-left: 16rpx;
  padding: 0;
}

.category-scroll {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  min-width: 100%;
}

.category-list.compact {
  margin-bottom: 16rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  margin-right: 14rpx;
  min-height: 58rpx;
  padding: 0 22rpx;
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  background: #ffffff;
  color: #475467;
  font-size: 24rpx;
}

.category-item.active {
  border-color: #1f5fbf;
  background: #eaf1ff;
  color: #1f5fbf;
  font-weight: 700;
}

.result-count {
  color: #667085;
  font-size: 24rpx;
  font-weight: 400;
}

.knowledge-list,
.template-list {
  display: block;
}

.knowledge-card,
.template-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.knowledge-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.knowledge-title {
  flex: 1;
  color: #101828;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.knowledge-answer {
  margin-top: 16rpx;
  color: #344054;
  line-height: 1.65;
}

.sensitive {
  margin-top: 16rpx;
  padding: 16rpx;
  border-left: 6rpx solid #a15c00;
  background: #fff8ed;
  color: #8a4b00;
  line-height: 1.55;
}

.knowledge-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.knowledge-tags .tag {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.knowledge-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
  color: #667085;
  font-size: 24rpx;
}

.knowledge-meta text {
  margin-right: 18rpx;
}

.link-button {
  width: 210rpx;
  min-height: 64rpx;
  margin-top: 20rpx;
  margin-left: 0;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.template-main {
  display: flex;
  align-items: flex-start;
}

.template-type {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 8rpx;
  background: #eef2f6;
  color: #344054;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 18rpx;
}

.template-info {
  flex: 1;
  min-width: 0;
}

.template-name {
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.template-desc {
  margin-top: 8rpx;
  color: #667085;
  line-height: 1.55;
}

.template-meta {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
}

.download-button {
  width: 210rpx;
  min-height: 64rpx;
  margin-top: 18rpx;
  margin-left: 102rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
}
