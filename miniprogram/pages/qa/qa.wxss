.search-panel {
  margin-top: 28rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.search-label {
  margin-bottom: 14rpx;
  color: #344054;
  font-size: 25rpx;
  font-weight: 700;
}

.search-row {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  width: 100%;
  min-height: 82rpx;
  padding: 0 22rpx;
  border: 1rpx solid #b8c2d0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #101828;
  font-size: 28rpx;
}

.search-button {
  width: 148rpx;
  min-height: 82rpx;
  margin-left: 16rpx;
  padding: 0;
}

.category-scroll {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  min-width: 100%;
}

.category-list.compact {
  margin-bottom: 16rpx;
}

.category-item {
  display: inline-flex;
  align-items: center;
  margin-right: 14rpx;
  min-height: 60rpx;
  padding: 0 22rpx;
  border: 1rpx solid #c9d3df;
  border-radius: 8rpx;
  background: #ffffff;
  color: #475467;
  font-size: 24rpx;
}

.category-item.active {
  border-color: #1f5fbf;
  background: #eaf1ff;
  color: #1f5fbf;
  font-weight: 700;
}

.result-count {
  color: #667085;
  font-size: 24rpx;
  font-weight: 400;
}

.knowledge-list,
.template-list {
  display: block;
}

.knowledge-card,
.template-card {
  margin-bottom: 18rpx;
  padding: 26rpx;
}

.knowledge-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.knowledge-title-wrap {
  flex: 1;
  min-width: 0;
  margin-right: 18rpx;
}

.knowledge-title {
  color: #101828;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.knowledge-source {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
}

.match-info {
  display: inline-flex;
  margin-top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #1f5fbf;
  font-size: 23rpx;
}

.knowledge-answer {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  color: #344054;
  line-height: 1.65;
}

.sensitive {
  margin-top: 16rpx;
  padding: 16rpx;
  border-left: 6rpx solid #a15c00;
  background: #fff8ed;
  color: #8a4b00;
  line-height: 1.55;
}

.knowledge-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.knowledge-tags .tag {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.knowledge-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
  color: #667085;
  font-size: 24rpx;
}

.knowledge-meta text {
  margin-right: 18rpx;
}

.link-button {
  width: 210rpx;
  min-height: 64rpx;
  margin-left: 0;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.feedback-button {
  width: 150rpx;
  min-height: 64rpx;
  margin-left: 14rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
}

.empty-feedback-button {
  width: 220rpx;
  min-height: 64rpx;
  margin-top: 16rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
}

.knowledge-actions,
.template-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 18rpx;
}

.template-card {
  position: relative;
  overflow: hidden;
}

.template-card::before {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
  background: #2d7d78;
  content: "";
}

.template-main {
  display: flex;
  align-items: flex-start;
}

.template-type {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border-radius: 8rpx;
  background: #e7f8ef;
  color: #067647;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 18rpx;
}

.template-info {
  flex: 1;
  min-width: 0;
}

.template-name {
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.template-desc {
  margin-top: 8rpx;
  color: #667085;
  line-height: 1.55;
}

.template-meta {
  margin-top: 10rpx;
  color: #667085;
  font-size: 23rpx;
}

.download-button {
  width: 210rpx;
  min-height: 64rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
}

@media (max-width: 520px) {
  .search-row {
    align-items: stretch;
    flex-direction: column;
  }

  .search-button {
    width: 100%;
    margin-top: 14rpx;
    margin-left: 0;
  }

  .knowledge-head {
    display: block;
  }

  .knowledge-title-wrap {
    margin-right: 0;
    margin-bottom: 12rpx;
  }
}
