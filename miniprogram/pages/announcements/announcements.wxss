.search-panel {
  margin-top: 28rpx;
  padding: 24rpx;
  background: #fbfcfe;
}

.search-row {
  display: flex;
  align-items: center;
}

.search-input {
  flex: 1;
  width: 100%;
  min-height: 82rpx;
  padding: 0 22rpx;
  border: 1rpx solid #b8c2d0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #101828;
  font-size: 28rpx;
}

.search-button {
  width: 148rpx;
  min-height: 82rpx;
  margin-left: 16rpx;
  padding: 0;
}

.filter-row {
  display: flex;
  align-items: center;
  margin-top: 18rpx;
}

.unread-button {
  flex: 0 0 160rpx;
  min-height: 60rpx;
  margin-right: 14rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
}

.tag-scroll {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.tag-list {
  display: inline-flex;
  min-width: 100%;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  min-height: 60rpx;
  margin-right: 14rpx;
  padding: 0 22rpx;
  border: 1rpx solid #c9d3df;
  border-radius: 8rpx;
  background: #ffffff;
  color: #475467;
  font-size: 24rpx;
}

.tag-item.active {
  border-color: #1f5fbf;
  background: #eaf1ff;
  color: #1f5fbf;
  font-weight: 700;
}

.result-count {
  color: #667085;
  font-size: 24rpx;
  font-weight: 400;
}

.announcement-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-left: 8rpx solid #1f5fbf;
}

.announcement-head,
.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.announcement-head > view:first-child,
.detail-head > view:first-child {
  flex: 1;
  min-width: 0;
}

.announcement-title,
.detail-title {
  color: #101828;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.announcement-meta,
.detail-meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.status-tags {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.announcement-summary,
.detail-content {
  margin-top: 16rpx;
  color: #475467;
  line-height: 1.65;
}

.announcement-tags,
.detail-tags {
  margin-top: 16rpx;
}

.detail-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  padding: 28rpx;
  background: rgba(16, 24, 40, 0.42);
}

.detail-panel {
  width: 100%;
  max-height: 82vh;
  overflow-y: auto;
  padding: 28rpx;
}

.close-button {
  flex: 0 0 92rpx;
}

.detail-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 22rpx;
}

.source-button {
  min-height: 64rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

@media (max-width: 520px) {
  .search-row,
  .filter-row,
  .announcement-head,
  .detail-head {
    align-items: stretch;
    flex-direction: column;
  }

  .search-button,
  .unread-button,
  .close-button {
    width: 100%;
    margin-left: 0;
    margin-right: 0;
  }

  .search-button {
    margin-top: 14rpx;
  }
}
