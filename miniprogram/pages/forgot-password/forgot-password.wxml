<view class="page forgot-page">
  <view class="page-header">
    <view class="page-title">找回密码</view>
    <view class="page-subtitle">通过学号和姓名提交找回申请。正式环境中重置凭证应通过学院确认渠道发送。</view>
  </view>

  <view class="forgot-card card">
    <view class="form-row">
      <text class="form-label">学号</text>
      <input class="form-input" value="{{studentNo}}" maxlength="10" type="number" placeholder="请输入 10 位数字学号" bindinput="onStudentNoInput" />
    </view>
    <view class="form-row">
      <text class="form-label">姓名</text>
      <input class="form-input" value="{{name}}" placeholder="请输入学生姓名" bindinput="onNameInput" />
    </view>
    <button class="secondary-button full-button" bindtap="requestReset">提交找回申请</button>

    <view class="reset-area">
      <view class="reset-token" wx:if="{{serverResetToken}}">开发环境重置凭证：{{serverResetToken}}</view>
      <view class="form-row">
        <text class="form-label">重置凭证</text>
        <input class="form-input" value="{{resetToken}}" placeholder="请输入学院确认渠道收到的重置凭证" bindinput="onResetTokenInput" />
      </view>
      <view class="form-row">
        <text class="form-label">新密码</text>
        <input class="form-input" value="{{newPassword}}" password placeholder="请输入新密码" bindinput="onNewPasswordInput" />
      </view>
      <button class="primary-button full-button" bindtap="confirmReset">设置新密码</button>
    </view>
  </view>
</view>
