.score-card {
  margin-top: 28rpx;
  padding: 30rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  text-align: center;
}

.score-number {
  color: #1f5fbf;
  font-size: 54rpx;
  font-weight: 700;
}

.score-text {
  margin-top: 6rpx;
  color: #667085;
}

.retry-button {
  width: 180rpx;
  min-height: 64rpx;
  margin-top: 22rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.answer-progress {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding: 22rpx 24rpx;
}

.answer-progress-title {
  color: #101828;
  font-weight: 700;
}

.answer-progress-text {
  margin-top: 6rpx;
  color: #667085;
  font-size: 24rpx;
}

.question-list {
  display: block;
  margin-top: 28rpx;
}

.question-card {
  margin-bottom: 18rpx;
  padding: 26rpx;
}

.question-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.question-stem {
  margin-top: 18rpx;
  color: #101828;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.45;
}

.option-list {
  display: block;
  margin-top: 20rpx;
}

.option {
  display: flex;
  align-items: center;
  min-height: 76rpx;
  margin-bottom: 14rpx;
  padding: 14rpx 16rpx;
  border: 1rpx solid #c9d3df;
  border-radius: 8rpx;
  background: #ffffff;
  color: #344054;
  line-height: 1.45;
}

.option radio {
  margin-right: 12rpx;
}

.option.selected {
  border-color: #1f5fbf;
  background: #eaf1ff;
  color: #1f5fbf;
  font-weight: 600;
}

.explanation {
  margin-top: 18rpx;
  padding: 16rpx;
  border-left: 6rpx solid #1f5fbf;
  background: #f2f6ff;
  color: #344054;
  line-height: 1.6;
}

.submit-bar {
  position: sticky;
  bottom: 0;
  padding: 18rpx 0 8rpx;
  background: linear-gradient(180deg, rgba(238, 243, 248, 0) 0%, #eef3f8 42%);
}

.submit-button {
  width: 100%;
  margin-top: 28rpx;
}
