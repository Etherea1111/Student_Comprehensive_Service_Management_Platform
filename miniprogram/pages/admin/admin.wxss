.admin-user {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
}

.admin-name {
  color: #101828;
  font-size: 34rpx;
  font-weight: 700;
}

.admin-role {
  margin-top: 8rpx;
  color: #667085;
}

.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.metric {
  width: 49%;
  margin-bottom: 16rpx;
  padding: 24rpx;
  position: relative;
  overflow: hidden;
}

.metric::after {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #d7e6ff;
  content: "";
}

.metric-value {
  color: #1f5fbf;
  font-size: 42rpx;
  font-weight: 700;
}

.metric-label {
  margin-top: 8rpx;
  color: #667085;
}

.policy-card {
  padding: 8rpx 22rpx 22rpx;
  background: #fbfcfe;
}

.policy-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eaecf0;
}

.policy-row text:first-child {
  color: #667085;
}

.policy-note {
  margin-top: 18rpx;
  color: #475467;
  line-height: 1.55;
}

.manage-list,
.log-list,
.future-list,
.draft-list,
.import-list,
.review-list,
.template-manage-list,
.stage-list,
.progress-list,
.student-list {
  display: block;
}

.manage-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.manage-item {
  border-left: 8rpx solid #1f5fbf;
}

.manage-item > view {
  flex: 1;
  min-width: 0;
  margin-right: 18rpx;
}

.manage-title,
.future-name {
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
}

.manage-desc,
.future-desc {
  margin-top: 8rpx;
  color: #667085;
  line-height: 1.55;
}

.import-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 24rpx;
  border-left: 8rpx solid #1f5fbf;
}

.import-main {
  flex: 1;
  min-width: 0;
  margin-right: 18rpx;
}

.import-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.import-title {
  flex: 1;
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.import-desc {
  margin-top: 8rpx;
  color: #475467;
  line-height: 1.55;
}

.import-template,
.import-permission {
  margin-top: 8rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 1.45;
  word-break: break-all;
}

.import-button {
  flex: 0 0 156rpx;
  min-height: 64rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
}

.import-result {
  margin-top: 18rpx;
  padding: 22rpx;
  border-left: 8rpx solid #12b76a;
  background: #f6fef9;
}

.result-title {
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
}

.result-meta {
  margin-top: 10rpx;
  color: #475467;
  line-height: 1.55;
}

.error-list {
  margin-top: 14rpx;
}

.error-item {
  margin-top: 8rpx;
  color: #b42318;
  font-size: 24rpx;
  line-height: 1.45;
}

.draft-form {
  padding: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.form-row {
  display: block;
  margin-bottom: 18rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  color: #344054;
  font-weight: 700;
}

.form-input,
.form-textarea {
  width: 100%;
  border: 1rpx solid #b8c2d0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #101828;
  font-size: 28rpx;
}

.form-input {
  min-height: 72rpx;
  padding: 0 18rpx;
}

.form-textarea {
  min-height: 180rpx;
  padding: 18rpx;
  line-height: 1.55;
}

.form-textarea.small {
  min-height: 120rpx;
}

.form-split {
  display: flex;
  gap: 16rpx;
}

.form-split .form-row {
  flex: 1;
  min-width: 0;
}

.file-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
  padding: 18rpx;
  border: 1rpx dashed #8fa0b7;
  border-radius: 8rpx;
  background: #f8fafc;
}

.file-row > view {
  flex: 1;
  min-width: 0;
  margin-right: 18rpx;
}

.file-title {
  color: #101828;
  font-weight: 700;
}

.file-desc {
  margin-top: 6rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.5;
}

.file-button {
  flex: 0 0 150rpx;
  min-height: 64rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
}

.submit-draft-button {
  width: 100%;
  margin-top: 20rpx;
}

.draft-card {
  margin-bottom: 16rpx;
  padding: 22rpx;
  border-left: 8rpx solid #f2a93b;
}

.review-card,
.template-manage-card,
.stage-card,
.progress-card,
.student-card,
.stage-form,
.progress-form,
.template-form {
  margin-bottom: 16rpx;
  padding: 22rpx;
}

.review-card,
.template-manage-card {
  border-left: 8rpx solid #1f5fbf;
}

.review-top,
.stage-head,
.progress-head,
.student-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.review-top > view,
.stage-head > view,
.progress-head > view,
.student-head > view {
  flex: 1;
  min-width: 0;
}

.review-title,
.stage-title,
.progress-name,
.student-name {
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.review-meta,
.stage-code,
.progress-meta,
.student-meta,
.progress-detail {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.45;
}

.review-answer,
.stage-desc {
  margin-top: 12rpx;
  color: #475467;
  line-height: 1.6;
}

.review-tags {
  margin-top: 14rpx;
}

.review-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.compact-button {
  min-height: 58rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.admin-tabs {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
}

.stage-form,
.progress-form,
.template-form {
  background: #fbfcfe;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
  padding: 18rpx;
}

.search-row .form-input {
  flex: 1;
  min-width: 0;
}

.search-mini-button {
  flex: 0 0 120rpx;
  min-height: 70rpx;
  padding: 0 14rpx;
  font-size: 24rpx;
}

.student-card {
  border-left: 8rpx solid #667085;
}

.student-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10rpx;
  margin-top: 16rpx;
  color: #475467;
  font-size: 24rpx;
  line-height: 1.45;
}

.draft-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.draft-title {
  flex: 1;
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.draft-answer {
  margin-top: 12rpx;
  color: #475467;
  line-height: 1.6;
}

.draft-meta {
  margin-top: 12rpx;
  color: #667085;
  font-size: 23rpx;
}

.log-card,
.future-card {
  margin-bottom: 16rpx;
  padding: 22rpx;
}

.log-card {
  background: #fbfcfe;
}

.future-card {
  border-left: 8rpx solid #98a2b3;
}

.log-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.log-action {
  color: #101828;
  font-weight: 700;
}

.log-time {
  color: #667085;
  font-size: 23rpx;
}

.log-detail {
  margin-top: 10rpx;
  color: #475467;
  line-height: 1.55;
}

.future-api {
  margin-top: 10rpx;
  color: #475467;
  font-size: 22rpx;
  word-break: break-all;
}

@media (min-width: 760px) {
  .metric {
    width: 24%;
  }
}

@media (max-width: 520px) {
  .file-row {
    align-items: stretch;
    flex-direction: column;
  }

  .import-card,
  .review-top,
  .stage-head,
  .progress-head,
  .student-head,
  .search-row,
  .admin-tabs,
  .form-split {
    align-items: stretch;
    flex-direction: column;
  }

  .import-main {
    margin-right: 0;
    margin-bottom: 16rpx;
  }

  .import-button {
    flex: none;
    width: 100%;
  }

  .file-row > view {
    margin-right: 0;
    margin-bottom: 16rpx;
  }

  .file-button {
    flex: none;
    width: 100%;
  }

  .compact-button,
  .search-mini-button {
    flex: none;
    width: 100%;
  }
}
