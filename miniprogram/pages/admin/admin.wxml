<view class="page admin-page">
  <view class="page-header">
    <view class="page-title">管理员维护</view>
    <view class="page-subtitle">用于维护模块一、模块二的公开内容，并为后续模块预留管理接口。</view>
  </view>

  <view class="admin-user card">
    <view>
      <view class="admin-name">{{dashboard.user.name}}</view>
      <view class="admin-role">{{roleName}} · {{dashboard.user.college}}</view>
    </view>
    <text class="tag {{manageTagClass}}">{{manageStatusText}}</text>
  </view>

  <view class="section">
    <view class="section-title"><text>维护概览</text></view>
    <view class="metrics-grid">
      <view class="metric card" wx:for="{{dashboard.metrics}}" wx:key="label">
        <view class="metric-value">{{item.value}}</view>
        <view class="metric-label">{{item.label}}</view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>上传策略</text></view>
    <view class="policy-card card">
      <view class="policy-row">
        <text>文件类型</text>
        <text>{{uploadPolicy.allowedTypesText}}</text>
      </view>
      <view class="policy-row">
        <text>大小上限</text>
        <text>{{uploadPolicy.maxSizeMB}}MB</text>
      </view>
      <view class="policy-row">
        <text>复核要求</text>
        <text>{{auditRequiredText}}</text>
      </view>
      <view class="policy-note">{{uploadPolicy.ownerRule}}</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>可维护内容</text></view>
    <view class="manage-list">
      <view class="manage-item card">
        <view>
          <view class="manage-title">知识库条目</view>
          <view class="manage-desc">支持草稿录入、老师复核、发布、退回和归档。</view>
        </view>
        <text class="tag">模块一</text>
      </view>
      <view class="manage-item card">
        <view>
          <view class="manage-title">模板文件</view>
          <view class="manage-desc">支持通过导入维护文件元数据；真实环境需替换为签名下载链接。</view>
        </view>
        <text class="tag">模块一</text>
      </view>
      <view class="manage-item card">
        <view>
          <view class="manage-title">党团流程配置</view>
          <view class="manage-desc">支持节点名称、动作清单、提醒周期和学生进度维护。</view>
        </view>
        <text class="tag">模块二</text>
      </view>
      <view class="manage-item card">
        <view>
          <view class="manage-title">公告与精准推送</view>
          <view class="manage-desc">支持通知录入、官方来源、目标人群、站内和邮件队列投递。</view>
        </view>
        <text class="tag">模块三</text>
      </view>
      <view class="manage-item card">
        <view>
          <view class="manage-title">证明与盖章审批</view>
          <view class="manage-desc">支持学生申请、附件说明、分级审批、驳回修改和记录留痕。</view>
        </view>
        <text class="tag success">模块四</text>
      </view>
      <view class="manage-item card">
        <view>
          <view class="manage-title">日常工作记录</view>
          <view class="manage-desc">记录党团学活动、会议、材料和参与人数，沉淀客观台账。</view>
        </view>
        <text class="tag">P1</text>
      </view>
      <view class="manage-item card">
        <view>
          <view class="manage-title">账号权限维护</view>
          <view class="manage-desc">维护班团骨干、辅导员、学院领导等管理账号和额外权限。</view>
        </view>
        <text class="tag">P1</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>批量导入</text></view>
    <view class="import-list">
      <view class="import-card card" wx:for="{{importTasks}}" wx:key="key">
        <view class="import-main">
          <view class="import-title-row">
            <text class="import-title">{{item.title}}</text>
            <text class="tag {{item.tagClass}}">{{item.tagText}}</text>
          </view>
          <view class="import-desc">{{item.desc}}</view>
          <view class="import-template">模板：templates/import/{{item.templateName}}</view>
          <view class="import-permission">{{item.permissionText}}</view>
        </view>
        <button
          class="secondary-button import-button"
          disabled="{{item.disabled}}"
          data-kind="{{item.key}}"
          bindtap="chooseImportFile"
        >
          上传导入
        </button>
      </view>
    </view>
    <view class="import-result card" wx:if="{{importResult}}">
      <view class="result-title">{{importResult.title}}结果</view>
      <view class="result-meta">{{importResult.fileName}} · 共 {{importResult.total}} 行 · 成功 {{importResult.imported}} 行 · 异常 {{importResult.errorCount}} 行</view>
      <view class="error-list" wx:if="{{importResult.errors.length}}">
        <view class="error-item" wx:for="{{importResult.errors}}" wx:key="line">
          第 {{item.line}} 行 {{item.field}}：{{item.message}}
        </view>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>数据导出</text></view>
    <view class="import-list">
      <view class="import-card card" wx:for="{{exportTasks}}" wx:key="key">
        <view class="import-main">
          <view class="import-title-row">
            <text class="import-title">{{item.title}}</text>
            <text class="tag {{item.tagClass}}">{{item.tagText}}</text>
          </view>
          <view class="import-desc">导出 CSV 文件，用于线下归档、复核或交接。</view>
        </view>
        <button class="secondary-button import-button" disabled="{{item.disabled}}" data-kind="{{item.key}}" bindtap="exportData">导出</button>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>知识库录入</text></view>
    <view class="draft-form card">
      <view class="form-row">
        <text class="form-label">问题标题</text>
        <input class="form-input" value="{{draftForm.title}}" data-field="title" placeholder="如：奖学金评定材料提交时间" bindinput="onDraftInput" />
      </view>
      <view class="form-row">
        <text class="form-label">分类</text>
        <input class="form-input" value="{{draftForm.category}}" data-field="category" placeholder="如：奖助学金、党团事务" bindinput="onDraftInput" />
      </view>
      <view class="form-row">
        <text class="form-label">标签</text>
        <input class="form-input" value="{{draftForm.tagsText}}" data-field="tagsText" placeholder="用逗号分隔，如：奖学金,评奖评优" bindinput="onDraftInput" />
      </view>
      <view class="form-row">
        <text class="form-label">检索词</text>
        <input class="form-input" value="{{draftForm.keywordsText}}" data-field="keywordsText" placeholder="用逗号分隔，补充学生常用问法" bindinput="onDraftInput" />
      </view>
      <view class="form-row">
        <text class="form-label">标准答复</text>
        <textarea class="form-textarea" value="{{draftForm.answer}}" data-field="answer" placeholder="录入经老师确认的标准答复，避免自由生成不确定内容" bindinput="onDraftInput"></textarea>
      </view>
      <view class="form-row">
        <text class="form-label">官方链接</text>
        <input class="form-input" value="{{draftForm.officialLink}}" data-field="officialLink" placeholder="https://..." bindinput="onDraftInput" />
      </view>
      <view class="form-row">
        <text class="form-label">敏感提示</text>
        <input class="form-input" value="{{draftForm.sensitiveHint}}" data-field="sensitiveHint" placeholder="如：涉及隐私请联系辅导员处理" bindinput="onDraftInput" />
      </view>
      <view class="file-row">
        <view>
          <view class="file-title">{{selectedFileName}}</view>
          <view class="file-desc">支持 doc/docx/xls/xlsx/pdf/jpg/png，单个文件不超过 {{uploadPolicy.maxSizeMB}}MB。</view>
        </view>
        <button class="secondary-button file-button" bindtap="chooseDraftFile">选择文件</button>
      </view>
      <button class="primary-button submit-draft-button" bindtap="submitDraft">提交待复核草稿</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>本机草稿</text></view>
    <view class="draft-list" wx:if="{{drafts.length}}">
      <view class="draft-card card" wx:for="{{drafts}}" wx:key="id">
        <view class="draft-top">
          <text class="draft-title">{{item.title}}</text>
          <text class="tag warn">待复核</text>
        </view>
        <view class="draft-answer">{{item.answer}}</view>
        <view class="draft-meta">{{item.category}} · {{item.createdAt}} · {{item.fileName}}</view>
      </view>
    </view>
    <view class="empty" wx:else>暂无本机录入草稿。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>知识库复核与发布</text>
      <button class="text-button" bindtap="refreshManagedKnowledge">刷新</button>
    </view>
    <view class="review-list" wx:if="{{managedKnowledge.length}}">
      <view class="review-card card" wx:for="{{managedKnowledge}}" wx:key="id">
        <view class="review-top">
          <view>
            <view class="review-title">{{item.title}}</view>
            <view class="review-meta">{{item.category}} · {{item.owner}} · {{item.updatedAt}}</view>
          </view>
          <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <view class="review-answer">{{item.answer}}</view>
        <view class="review-warning" wx:if="{{item.reviewCommentText}}">{{item.reviewCommentText}}</view>
        <view class="review-tags" wx:if="{{item.tagsText}}">
          <text class="tag neutral">{{item.tagsText}}</text>
        </view>
        <view class="review-actions">
          <button class="secondary-button compact-button" wx:if="{{item.canPublish}}" data-id="{{item.id}}" bindtap="publishKnowledge">发布</button>
          <button class="secondary-button compact-button" wx:if="{{item.canReject}}" data-id="{{item.id}}" bindtap="rejectKnowledge">退回</button>
          <button class="secondary-button compact-button" wx:if="{{item.canArchive}}" data-id="{{item.id}}" bindtap="archiveKnowledge">归档</button>
          <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="viewKnowledgeVersions">历史</button>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>暂无可维护知识库条目。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>知识库反馈</text>
      <button class="text-button" bindtap="refreshKnowledgeFeedback">刷新</button>
    </view>
    <view class="review-list" wx:if="{{knowledgeFeedback.length}}">
      <view class="review-card card" wx:for="{{knowledgeFeedback}}" wx:key="id">
        <view class="review-top">
          <view>
            <view class="review-title">{{item.knowledgeTitleText}}</view>
            <view class="review-meta">{{item.feedbackType}} · {{item.queryText || '无检索词'}} · {{item.createdAt}}</view>
          </view>
          <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <view class="review-answer">{{item.feedbackText}}</view>
        <view class="review-actions" wx:if="{{item.canHandle}}">
          <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="handleKnowledgeFeedback">标记处理</button>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>暂无学生反馈。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>模板文件维护</text>
      <button class="text-button" bindtap="refreshManagedTemplates">刷新</button>
    </view>
    <view class="template-form card">
      <view class="form-row">
        <text class="form-label">模板名称</text>
        <input class="form-input" value="{{templateForm.name}}" data-field="name" placeholder="如：活动简报模板" bindinput="onTemplateInput" />
      </view>
      <view class="form-split">
        <view class="form-row">
          <text class="form-label">分类</text>
          <input class="form-input" value="{{templateForm.category}}" data-field="category" placeholder="如：学生组织" bindinput="onTemplateInput" />
        </view>
        <view class="form-row">
          <text class="form-label">文件类型</text>
          <input class="form-input" value="{{templateForm.fileType}}" data-field="fileType" placeholder="docx/xlsx/pdf" bindinput="onTemplateInput" />
        </view>
      </view>
      <view class="form-row">
        <text class="form-label">下载链接</text>
        <input class="form-input" value="{{templateForm.url}}" data-field="url" placeholder="上传文件后自动生成，或填写 https://..." bindinput="onTemplateInput" />
      </view>
      <view class="file-row">
        <view>
          <view class="file-title">模板文件上传</view>
          <view class="file-desc">支持 doc/docx/xls/xlsx/pdf/jpg/png，上传后自动回填下载链接。</view>
        </view>
        <button class="secondary-button file-button" bindtap="chooseTemplateFile">选择文件</button>
      </view>
      <view class="form-row">
        <text class="form-label">大小标识</text>
        <input class="form-input" value="{{templateForm.size}}" data-field="size" placeholder="如：42KB" bindinput="onTemplateInput" />
      </view>
      <view class="form-row">
        <text class="form-label">说明</text>
        <textarea class="form-textarea small" value="{{templateForm.description}}" data-field="description" placeholder="说明模板适用场景" bindinput="onTemplateInput"></textarea>
      </view>
      <button class="primary-button submit-draft-button" bindtap="submitTemplate">保存模板</button>
    </view>
    <view class="template-manage-list" wx:if="{{managedTemplates.length}}">
      <view class="template-manage-card card" wx:for="{{managedTemplates}}" wx:key="id">
        <view class="review-top">
          <view>
            <view class="review-title">{{item.name}}</view>
            <view class="review-meta">{{item.category}} · {{item.type || item.fileType}} · {{item.owner || '未设置维护人'}}</view>
          </view>
          <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
        </view>
        <view class="review-answer">{{item.description}}</view>
        <view class="review-actions">
          <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="editTemplate">编辑</button>
          <button class="secondary-button compact-button" wx:if="{{item.canArchive}}" data-id="{{item.id}}" bindtap="archiveTemplate">归档</button>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>暂无模板文件。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>公告与精准推送</text>
      <button class="text-button" bindtap="refreshManagedAnnouncements">刷新</button>
    </view>
    <view wx:if="{{dashboard.canManage}}">
      <view class="template-form card">
        <view class="form-row">
          <text class="form-label">通知标题</text>
          <input class="form-input" value="{{announcementForm.title}}" data-field="title" placeholder="如：奖学金评定材料提交提醒" bindinput="onAnnouncementInput" />
        </view>
        <view class="form-row">
          <text class="form-label">摘要</text>
          <input class="form-input" value="{{announcementForm.summary}}" data-field="summary" placeholder="用于列表展示的短摘要" bindinput="onAnnouncementInput" />
        </view>
        <view class="form-row">
          <text class="form-label">正文</text>
          <textarea class="form-textarea" value="{{announcementForm.content}}" data-field="content" placeholder="填写通知正文，来源应为学院或学校官方渠道" bindinput="onAnnouncementInput"></textarea>
        </view>
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">来源单位</text>
            <input class="form-input" value="{{announcementForm.sourceName}}" data-field="sourceName" placeholder="如：学院团委" bindinput="onAnnouncementInput" />
          </view>
          <view class="form-row">
            <text class="form-label">优先级</text>
            <input class="form-input" value="{{announcementForm.priority}}" data-field="priority" placeholder="low/normal/high/urgent" bindinput="onAnnouncementInput" />
          </view>
        </view>
        <view class="form-row">
          <text class="form-label">来源链接</text>
          <input class="form-input" value="{{announcementForm.sourceUrl}}" data-field="sourceUrl" placeholder="https://..." bindinput="onAnnouncementInput" />
        </view>
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">标签</text>
            <input class="form-input" value="{{announcementForm.tagsText}}" data-field="tagsText" placeholder="就业,实习,计算机类" bindinput="onAnnouncementInput" />
          </view>
          <view class="form-row">
            <text class="form-label">目标人群</text>
            <input class="form-input" value="{{announcementForm.targetsText}}" data-field="targetsText" placeholder="all:全部 或 major:计算机科学与技术" bindinput="onAnnouncementInput" />
            <view class="form-help">{{targetTypeHint}}</view>
          </view>
        </view>
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">发布时间</text>
            <input class="form-input" value="{{announcementForm.publishAt}}" data-field="publishAt" placeholder="YYYY-MM-DD HH:mm" bindinput="onAnnouncementInput" />
          </view>
          <view class="form-row">
            <text class="form-label">过期时间</text>
            <input class="form-input" value="{{announcementForm.expireAt}}" data-field="expireAt" placeholder="YYYY-MM-DD HH:mm" bindinput="onAnnouncementInput" />
          </view>
        </view>
        <button class="primary-button submit-draft-button" bindtap="submitAnnouncement">保存通知草稿</button>
      </view>
      <view class="template-form card">
        <view class="form-row">
          <text class="form-label">官方来源名称</text>
          <input class="form-input" value="{{sourceForm.sourceName}}" data-field="sourceName" placeholder="如：就业办、学院官网" bindinput="onSourceInput" />
        </view>
        <view class="form-row">
          <text class="form-label">来源链接</text>
          <input class="form-input" value="{{sourceForm.sourceUrl}}" data-field="sourceUrl" placeholder="https://..." bindinput="onSourceInput" />
        </view>
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">来源类型</text>
            <input class="form-input" value="{{sourceForm.sourceType}}" data-field="sourceType" placeholder="official_site/wechat/rss" bindinput="onSourceInput" />
          </view>
          <view class="form-row">
            <text class="form-label">默认标签</text>
            <input class="form-input" value="{{sourceForm.defaultTags}}" data-field="defaultTags" placeholder="就业,实习" bindinput="onSourceInput" />
          </view>
        </view>
        <button class="primary-button submit-draft-button" bindtap="submitAnnouncementSource">保存官方来源</button>
      </view>
      <view class="review-list" wx:if="{{announcementSources.length}}">
        <view class="review-card card" wx:for="{{announcementSources}}" wx:key="id">
          <view class="review-top">
            <view>
              <view class="review-title">{{item.sourceName}}</view>
              <view class="review-meta">{{item.sourceType}} · {{item.lastSyncedAt || '未同步'}}</view>
            </view>
            <text class="tag {{item.enabled ? 'success' : 'neutral'}}">{{item.enabled ? '启用' : '停用'}}</text>
          </view>
          <view class="review-answer">{{item.sourceUrl}}</view>
          <view class="review-actions">
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="editAnnouncementSource">编辑</button>
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="importAnnouncementSource">生成草稿</button>
          </view>
        </view>
      </view>
      <view class="review-list" wx:if="{{managedAnnouncements.length}}">
        <view class="review-card card" wx:for="{{managedAnnouncements}}" wx:key="id">
          <view class="review-top">
            <view>
              <view class="review-title">{{item.title}}</view>
              <view class="review-meta">{{item.sourceName || '未设置来源'}} · {{item.publishAt || item.updatedAt}}</view>
            </view>
            <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
          </view>
          <view class="review-answer">{{item.summary || item.content}}</view>
          <view class="review-tags" wx:if="{{item.tagsText}}">
            <text class="tag neutral">{{item.tagsText}}</text>
          </view>
          <view class="review-meta" wx:if="{{item.targetsText}}">目标：{{item.targetsText}} · 已读 {{item.readCount || 0}}</view>
          <view class="review-actions">
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="editAnnouncement">编辑</button>
            <button class="secondary-button compact-button" wx:if="{{item.canPublish}}" data-id="{{item.id}}" bindtap="publishAnnouncement">发布</button>
            <button class="secondary-button compact-button" wx:if="{{!item.canPublish}}" data-id="{{item.id}}" bindtap="dispatchAnnouncement">投递</button>
            <button class="secondary-button compact-button" wx:if="{{item.canWithdraw}}" data-id="{{item.id}}" bindtap="withdrawAnnouncement">撤回</button>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>暂无公告。</view>
    </view>
    <view class="empty" wx:else>当前角色无权维护公告。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>证明与盖章审批</text>
      <button class="text-button" bindtap="refreshManagedApprovals">刷新</button>
    </view>
    <view wx:if="{{canApproveRequests}}">
      <view class="search-row card">
        <input class="form-input" value="{{approvalKeyword}}" placeholder="按申请单号、标题、学号、姓名搜索" bindinput="onApprovalKeywordInput" />
        <button class="secondary-button search-mini-button" bindtap="refreshManagedApprovals">搜索</button>
      </view>
      <view class="review-list" wx:if="{{managedApprovals.length}}">
        <view class="review-card card" wx:for="{{managedApprovals}}" wx:key="id">
          <view class="review-top">
            <view>
              <view class="review-title">{{item.title}}</view>
              <view class="review-meta">{{item.requestNo}} · {{item.studentName}} {{item.studentNo}} · {{item.requestTypeText}}</view>
            </view>
            <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
          </view>
          <view class="review-answer">用途：{{item.purpose}}</view>
          <view class="review-answer" wx:if="{{item.description}}">{{item.description}}</view>
          <view class="review-answer" wx:if="{{item.confidentialDescription}}">涉密说明：{{item.confidentialDescription}}</view>
          <view class="review-answer" wx:if="{{item.previewContent}}">{{item.previewContent}}</view>
          <view class="review-answer" wx:if="{{item.rejectionReason}}">驳回原因：{{item.rejectionReason}}</view>
          <view class="review-meta">当前节点：{{item.currentStepText}} · 审批级次：{{item.approvalLevel || 1}}</view>
          <view class="review-actions" wx:if="{{item.canApprove}}">
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="approveRequest">{{item.nextApprovalAction || '通过'}}</button>
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="rejectRequest">驳回</button>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>暂无审批事项。</view>
    </view>
    <view class="empty" wx:else>当前角色无权审批证明或盖章申请。</view>
  </view>

  <view class="section">
    <view class="section-title"><text>流程节点维护</text></view>
    <view wx:if="{{canManageProcess}}">
      <view class="admin-tabs card">
        <button class="secondary-button compact-button" data-type="party" bindtap="switchManageProcessType">入党</button>
        <button class="secondary-button compact-button" data-type="league" bindtap="switchManageProcessType">入团</button>
        <text class="tag neutral">当前：{{activeManageProcessType}}</text>
      </view>
      <view class="stage-form card">
        <view class="form-row">
          <text class="form-label">节点编码</text>
          <input class="form-input" value="{{stageForm.stageCode}}" data-field="stageCode" placeholder="如：activist" bindinput="onStageInput" />
        </view>
        <view class="form-row">
          <text class="form-label">节点名称</text>
          <input class="form-input" value="{{stageForm.name}}" data-field="name" placeholder="如：入党积极分子" bindinput="onStageInput" />
        </view>
        <view class="form-row">
          <text class="form-label">短名称</text>
          <input class="form-input" value="{{stageForm.shortName}}" data-field="shortName" placeholder="用于流程条展示" bindinput="onStageInput" />
        </view>
        <view class="form-row">
          <text class="form-label">节点说明</text>
          <textarea class="form-textarea small" value="{{stageForm.description}}" data-field="description" placeholder="说明该阶段要求" bindinput="onStageInput"></textarea>
        </view>
        <view class="form-row">
          <text class="form-label">动作清单</text>
          <input class="form-input" value="{{stageForm.actionsText}}" data-field="actionsText" placeholder="用逗号分隔，如：提交思想汇报,参加培训" bindinput="onStageInput" />
        </view>
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">提醒天数</text>
            <input class="form-input" value="{{stageForm.reminderDays}}" data-field="reminderDays" type="number" bindinput="onStageInput" />
          </view>
          <view class="form-row">
            <text class="form-label">排序</text>
            <input class="form-input" value="{{stageForm.sortOrder}}" data-field="sortOrder" type="number" bindinput="onStageInput" />
          </view>
        </view>
        <button class="primary-button submit-draft-button" bindtap="submitStage">保存流程节点</button>
      </view>
      <view class="stage-list">
        <view class="stage-card card" wx:for="{{managedStages}}" wx:key="stageCode">
          <view class="stage-head">
            <view>
              <view class="stage-title">{{item.sortOrder}}. {{item.name}}</view>
              <view class="stage-code">{{item.stageCode}} · {{item.reminderDays}} 天提醒</view>
            </view>
            <button class="secondary-button compact-button" data-code="{{item.stageCode}}" bindtap="editStage">编辑</button>
          </view>
          <view class="stage-desc">{{item.description}}</view>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>当前角色无权维护流程配置。</view>
  </view>

  <view class="section">
    <view class="section-title"><text>学生进度维护</text></view>
    <view wx:if="{{canManageProcess}}">
      <view class="reminder-list" wx:if="{{dueReminders.length}}">
        <view class="reminder-card card" wx:for="{{dueReminders}}" wx:key="studentNo">
          <view>
            <view class="progress-name">{{item.name}} · {{item.studentNo}}</view>
            <view class="progress-meta">{{item.processType}} · {{item.currentStageName || item.currentStageCode}} · {{item.nextDeadline}}</view>
          </view>
          <text class="tag warn">{{item.statusText}}</text>
        </view>
      </view>
      <view class="search-row card">
        <input class="form-input" value="{{progressKeyword}}" placeholder="按学号、姓名、班级搜索" bindinput="onProgressKeywordInput" />
        <button class="secondary-button search-mini-button" bindtap="refreshManagedProgress">搜索</button>
      </view>
      <view class="progress-form card">
        <view class="form-row">
          <text class="form-label">学号</text>
          <input class="form-input" value="{{progressForm.studentNo}}" data-field="studentNo" maxlength="10" type="number" bindinput="onProgressInput" />
        </view>
        <view class="form-row">
          <text class="form-label">当前节点编码</text>
          <input class="form-input" value="{{progressForm.currentStageCode}}" data-field="currentStageCode" placeholder="如：activist/member" bindinput="onProgressInput" />
        </view>
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">进入时间</text>
            <input class="form-input" value="{{progressForm.startedAt}}" data-field="startedAt" placeholder="YYYY-MM-DD" bindinput="onProgressInput" />
          </view>
          <view class="form-row">
            <text class="form-label">下一节点</text>
            <input class="form-input" value="{{progressForm.nextDeadline}}" data-field="nextDeadline" placeholder="YYYY-MM-DD" bindinput="onProgressInput" />
          </view>
        </view>
        <view class="form-row">
          <text class="form-label">负责人</text>
          <input class="form-input" value="{{progressForm.advisor}}" data-field="advisor" bindinput="onProgressInput" />
        </view>
        <view class="form-row">
          <text class="form-label">已完成动作</text>
          <input class="form-input" value="{{progressForm.completedActionsText}}" data-field="completedActionsText" placeholder="用逗号分隔" bindinput="onProgressInput" />
        </view>
        <button class="primary-button submit-draft-button" bindtap="submitProgress">保存学生进度</button>
      </view>
      <view class="progress-list">
        <view class="progress-card card" wx:for="{{managedProgress}}" wx:key="studentNo">
          <view class="progress-head">
            <view>
              <view class="progress-name">{{item.name}} · {{item.studentNo}}</view>
              <view class="progress-meta">{{item.className}} · {{item.currentStageName || item.currentStageCode}}</view>
            </view>
            <button class="secondary-button compact-button" data-student-no="{{item.studentNo}}" bindtap="editProgress">编辑</button>
          </view>
          <view class="progress-detail">下一节点：{{item.nextDeadline || '未设置'}} · 负责人：{{item.advisor || '未设置'}}</view>
          <view class="progress-detail">已完成：{{item.completedActionsText || '暂无记录'}}</view>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>当前角色无权维护学生进度。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>党团学工作记录</text>
      <button class="text-button" bindtap="refreshWorkRecords">刷新</button>
    </view>
    <view wx:if="{{canManageProcess}}">
      <view class="search-row card">
        <input class="form-input" value="{{workRecordKeyword}}" placeholder="按标题、组织者、内容搜索" bindinput="onWorkRecordKeywordInput" />
        <button class="secondary-button search-mini-button" bindtap="refreshWorkRecords">搜索</button>
      </view>
      <view class="progress-form card">
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">记录类型</text>
            <input class="form-input" value="{{workRecordForm.recordType}}" data-field="recordType" placeholder="party/league/student_org/class_affairs" bindinput="onWorkRecordInput" />
          </view>
          <view class="form-row">
            <text class="form-label">日期</text>
            <input class="form-input" value="{{workRecordForm.occurredAt}}" data-field="occurredAt" placeholder="YYYY-MM-DD" bindinput="onWorkRecordInput" />
          </view>
        </view>
        <view class="form-row">
          <text class="form-label">标题</text>
          <input class="form-input" value="{{workRecordForm.title}}" data-field="title" placeholder="如：积极分子培训签到" bindinput="onWorkRecordInput" />
        </view>
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">组织者</text>
            <input class="form-input" value="{{workRecordForm.organizer}}" data-field="organizer" bindinput="onWorkRecordInput" />
          </view>
          <view class="form-row">
            <text class="form-label">参与人数</text>
            <input class="form-input" value="{{workRecordForm.participantsCount}}" data-field="participantsCount" type="number" bindinput="onWorkRecordInput" />
          </view>
        </view>
        <view class="form-row">
          <text class="form-label">参与学号</text>
          <input class="form-input" value="{{workRecordForm.studentNos}}" data-field="studentNos" placeholder="用逗号分隔，可为空" bindinput="onWorkRecordInput" />
        </view>
        <view class="form-row">
          <text class="form-label">内容记录</text>
          <textarea class="form-textarea small" value="{{workRecordForm.content}}" data-field="content" placeholder="记录会议、活动、材料或客观事实" bindinput="onWorkRecordInput"></textarea>
        </view>
        <view class="form-row">
          <text class="form-label">材料摘要</text>
          <input class="form-input" value="{{workRecordForm.materialsSummary}}" data-field="materialsSummary" placeholder="如：签到表、照片、会议纪要已上传" bindinput="onWorkRecordInput" />
        </view>
        <button class="primary-button submit-draft-button" bindtap="submitWorkRecord">保存工作记录</button>
      </view>
      <view class="progress-list" wx:if="{{workRecords.length}}">
        <view class="progress-card card" wx:for="{{workRecords}}" wx:key="id">
          <view class="progress-head">
            <view>
              <view class="progress-name">{{item.title}}</view>
              <view class="progress-meta">{{item.recordTypeText}} · {{item.occurredAt}} · {{item.organizer || '未设置组织者'}}</view>
            </view>
            <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
          </view>
          <view class="progress-detail">人数：{{item.participantsCount}} · 材料：{{item.materialsSummary || '未记录'}}</view>
          <view class="progress-detail">{{item.content || '暂无内容'}}</view>
          <view class="review-actions">
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="editWorkRecord">编辑</button>
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="archiveWorkRecord">归档</button>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>暂无工作记录。</view>
    </view>
    <view class="empty" wx:else>当前角色无权维护工作记录。</view>
  </view>

  <view class="section">
    <view class="section-title"><text>学生档案与隐私</text></view>
    <view class="search-row card">
      <input class="form-input" value="{{studentKeyword}}" placeholder="按学号、姓名、班级、专业搜索" bindinput="onStudentKeywordInput" />
      <button class="secondary-button search-mini-button" bindtap="refreshManagedStudents">搜索</button>
    </view>
    <view class="student-list" wx:if="{{managedStudents.length}}">
      <view class="student-card card" wx:for="{{managedStudents}}" wx:key="studentNo">
        <view class="student-head">
          <view>
            <view class="student-name">{{item.name}} · {{item.studentNo}}</view>
            <view class="student-meta">{{item.grade}} · {{item.major}} · {{item.className}}</view>
          </view>
          <text class="tag {{item.sensitiveTagClass}}">{{item.sensitiveTagText}}</text>
        </view>
        <view class="student-grid">
          <view>手机号：{{item.phone || '未登记'}}</view>
          <view>身份证：{{item.idCard || '未登记'}}</view>
          <view>生源地：{{item.birthplace || '未登记'}}</view>
          <view>户籍：{{item.householdRegister || '未登记'}}</view>
          <view>导师/负责人：{{item.advisor || '未登记'}}</view>
          <view>学籍状态：{{item.studentStatus || '未登记'}}</view>
          <view>校友状态：{{item.alumniText}}</view>
          <view>获奖情况：{{item.awards || '未登记'}}</view>
        </view>
      </view>
    </view>
    <view class="empty" wx:else>暂无匹配学生档案。</view>
  </view>

  <view class="section">
    <view class="section-title"><text>操作日志</text></view>
    <view class="log-list" wx:if="{{logs.length}}">
      <view class="log-card card" wx:for="{{logs}}" wx:key="id">
        <view class="log-top">
          <text class="log-action">{{item.action}}</text>
          <text class="log-time">{{item.createdAt}}</text>
        </view>
        <view class="log-detail">{{item.operator}}（{{item.role}}）处理：{{item.target}}</view>
      </view>
    </view>
    <view class="empty" wx:else>当前角色无权查看操作日志。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>账号权限维护</text>
      <button class="text-button" bindtap="refreshManagedAccounts">刷新</button>
    </view>
    <view wx:if="{{canManageAccounts}}">
      <view class="search-row card">
        <input class="form-input" value="{{accountKeyword}}" placeholder="按账号、姓名或学号搜索" bindinput="onAccountKeywordInput" />
        <button class="secondary-button search-mini-button" bindtap="refreshManagedAccounts">搜索</button>
      </view>
      <view class="progress-form card">
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">账号</text>
            <input class="form-input" value="{{accountForm.accountName}}" data-field="accountName" placeholder="如：league_secretary_2024" bindinput="onAccountInput" />
          </view>
          <view class="form-row">
            <text class="form-label">显示名</text>
            <input class="form-input" value="{{accountForm.displayName}}" data-field="displayName" placeholder="如：2024级团支书" bindinput="onAccountInput" />
          </view>
        </view>
        <view class="form-split">
          <view class="form-row">
            <text class="form-label">角色</text>
            <input class="form-input" value="{{accountForm.role}}" data-field="role" placeholder="class_leader/counselor/college_leader" bindinput="onAccountInput" />
          </view>
          <view class="form-row">
            <text class="form-label">绑定学号</text>
            <input class="form-input" value="{{accountForm.studentNo}}" data-field="studentNo" placeholder="管理员账号可留空" bindinput="onAccountInput" />
          </view>
        </view>
        <view class="form-row">
          <text class="form-label">初始密码</text>
          <input class="form-input" value="{{accountForm.password}}" data-field="password" password bindinput="onAccountInput" />
        </view>
        <view class="form-row">
          <text class="form-label">额外权限</text>
          <input class="form-input" value="{{accountForm.extraPermissionsText}}" data-field="extraPermissionsText" placeholder="用逗号分隔，如：manage_public_content" bindinput="onAccountInput" />
        </view>
        <button class="primary-button submit-draft-button" bindtap="submitAccount">保存账号</button>
      </view>
      <view class="student-list" wx:if="{{managedAccounts.length}}">
        <view class="student-card card" wx:for="{{managedAccounts}}" wx:key="id">
          <view class="student-head">
            <view>
              <view class="student-name">{{item.accountName}} · {{item.displayName || item.studentName || '未命名'}}</view>
              <view class="student-meta">{{item.roleText}} · {{item.bindText}} · {{item.lastLoginAt || '未登录'}}</view>
            </view>
            <text class="tag {{item.passwordChangeDisabled ? 'warn' : 'success'}}">{{item.passwordChangeDisabled ? '禁止改密' : '可改密'}}</text>
          </view>
          <view class="progress-detail">额外权限：{{item.extraPermissionsText || '无'}}</view>
          <view class="review-actions">
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="editAccount">编辑</button>
            <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="disableAccount">禁用</button>
          </view>
        </view>
      </view>
      <view class="empty" wx:else>暂无账号。</view>
    </view>
    <view class="empty" wx:else>当前角色无权维护账号权限。</view>
  </view>

  <view class="section">
    <view class="section-title"><text>后续接口</text></view>
    <view class="future-list">
      <view class="future-card card" wx:for="{{futureModules}}" wx:key="id">
        <view class="future-name">{{item.name}}</view>
        <view class="future-desc">{{item.description}}</view>
        <view class="future-api">{{item.api}}</view>
      </view>
    </view>
  </view>
</view>
