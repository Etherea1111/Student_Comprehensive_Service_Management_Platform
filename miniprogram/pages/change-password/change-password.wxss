.password-card {
  margin-top: 28rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
}

.form-row {
  margin-bottom: 18rpx;
}

.form-label {
  display: block;
  margin-bottom: 10rpx;
  color: #344054;
  font-weight: 700;
}

.form-input {
  width: 100%;
  min-height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #b8c2d0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #101828;
  font-size: 28rpx;
}

.full-button {
  width: 100%;
  margin-top: 20rpx;
}
