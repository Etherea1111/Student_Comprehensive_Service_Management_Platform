<view class="page password-page">
  <view class="page-header">
    <view class="page-title">修改密码</view>
    <view class="page-subtitle">密码长度需为 8-64 位。首次使用初始密码登录后，请及时修改。</view>
  </view>

  <view class="password-card card">
    <view class="form-row">
      <text class="form-label">原密码</text>
      <input class="form-input" value="{{oldPassword}}" password placeholder="请输入原密码" bindinput="onOldPasswordInput" />
    </view>
    <view class="form-row">
      <text class="form-label">新密码</text>
      <input class="form-input" value="{{newPassword}}" password placeholder="请输入新密码" bindinput="onNewPasswordInput" />
    </view>
    <view class="form-row">
      <text class="form-label">确认新密码</text>
      <input class="form-input" value="{{confirmPassword}}" password placeholder="请再次输入新密码" bindinput="onConfirmPasswordInput" />
    </view>
    <button class="primary-button full-button" bindtap="submitChange">确认修改</button>
  </view>
</view>
