.profile-card {
  display: flex;
  align-items: center;
  padding: 28rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 8rpx;
  background: #23395d;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
}

.profile-main {
  flex: 1;
  min-width: 0;
  margin-left: 22rpx;
}

.profile-name {
  color: #101828;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-meta {
  margin-top: 8rpx;
  color: #667085;
}

.profile-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.profile-tags .tag {
  margin-right: 10rpx;
  margin-bottom: 10rpx;
}

.info-card {
  padding: 6rpx 22rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eaecf0;
  color: #344054;
}

.info-row:last-child {
  border-bottom: 0;
}

.info-row text:first-child {
  color: #667085;
}

.action-list {
  display: block;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.action-title {
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
}

.action-desc {
  margin-top: 8rpx;
  color: #667085;
  line-height: 1.5;
}

.arrow {
  color: #98a2b3;
  font-size: 48rpx;
  line-height: 1;
}

.privacy {
  padding: 24rpx;
  color: #475467;
  line-height: 1.65;
}
