<view class="page mine-page">
  <view class="profile-card card">
    <view class="avatar">{{avatarText}}</view>
    <view class="profile-main">
      <view class="profile-name">{{user.name}}</view>
      <view class="profile-meta">{{user.studentNo}} · {{user.className}}</view>
      <view class="profile-tags">
        <text class="tag">{{roleName}}</text>
        <text class="tag neutral">{{user.politicalStatus}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>账号与权限</text></view>
    <view class="info-card card">
      <view class="info-row">
        <text>学院</text>
        <text>{{user.college}}</text>
      </view>
      <view class="info-row">
        <text>专业</text>
        <text>{{user.major}}</text>
      </view>
      <view class="info-row">
        <text>年级</text>
        <text>{{user.grade}}</text>
      </view>
      <view class="info-row">
        <text>管理员账号</text>
        <text>{{adminAccountText}}</text>
      </view>
      <view class="info-row">
        <text>敏感数据</text>
        <text>{{sensitiveVisibleText}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>当前权限</text></view>
    <view class="permission-card card">
      <text class="tag {{item.tagClass}}" wx:for="{{permissionItems}}" wx:key="key">{{item.label}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>快捷入口</text></view>
    <view class="action-list">
      <view class="action-item card card-pressable" bindtap="goQa">
        <view class="action-icon">问</view>
        <view>
          <view class="action-title">政策问答与模板</view>
          <view class="action-desc">查询标准答复、复制模板下载链接。</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item card card-pressable" bindtap="goProcess">
        <view class="action-icon green">党</view>
        <view>
          <view class="action-title">我的党团流程</view>
          <view class="action-desc">查看阶段进度、材料动作和节点提醒。</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item card card-pressable" bindtap="goAnnouncements">
        <view class="action-icon brown">通</view>
        <view>
          <view class="action-title">通知中心</view>
          <view class="action-desc">查看公告、就业、实习等精准推送信息。</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item card card-pressable" bindtap="goApprovals">
        <view class="action-icon purple">审</view>
        <view>
          <view class="action-title">证明与审批</view>
          <view class="action-desc">提交证明、盖章申请并查看审批结果。</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item card card-pressable" wx:if="{{canEnterAdmin}}" bindtap="goAdmin">
        <view class="action-icon gray">管</view>
        <view>
          <view class="action-title">管理员维护</view>
          <view class="action-desc">维护知识库、模板、流程配置，查看操作日志。</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item card card-pressable" bindtap="goChangePassword">
        <view class="action-icon gray">密</view>
        <view>
          <view class="action-title">修改密码</view>
          <view class="action-desc">更新学号密码登录凭据。</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item card card-pressable" bindtap="logout">
        <view class="action-icon gray">退</view>
        <view>
          <view class="action-title">退出登录</view>
          <view class="action-desc">清除本机登录状态并返回登录页。</view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title"><text>隐私说明</text></view>
    <view class="privacy card">
      身份证号、手机号、生源地、户籍、休学与延毕等敏感信息不在学生端公开展示；老师和管理员查看敏感数据时应按权限控制并保留操作记录。
    </view>
  </view>
</view>
