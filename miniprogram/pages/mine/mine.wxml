<view class="page mine-page">
  <view class="profile-card card">
    <view class="avatar">{{avatarText}}</view>
    <view class="profile-main">
      <view class="profile-name">{{user.name}}</view>
      <view class="profile-meta">{{user.studentNo}} · {{user.className}}</view>
      <view class="profile-tags">
        <text class="tag">{{roleName}}</text>
        <text class="tag neutral">{{user.politicalStatus}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">账号与权限</view>
    <view class="info-card card">
      <view class="info-row">
        <text>学院</text>
        <text>{{user.college}}</text>
      </view>
      <view class="info-row">
        <text>专业</text>
        <text>{{user.major}}</text>
      </view>
      <view class="info-row">
        <text>年级</text>
        <text>{{user.grade}}</text>
      </view>
      <view class="info-row">
        <text>管理员账号</text>
        <text>{{adminAccountText}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">快捷入口</view>
    <view class="action-list">
      <view class="action-item card" bindtap="goQa">
        <view>
          <view class="action-title">政策问答与模板</view>
          <view class="action-desc">查询标准答复、复制模板下载链接。</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item card" bindtap="goProcess">
        <view>
          <view class="action-title">我的党团流程</view>
          <view class="action-desc">查看阶段进度、材料动作和节点提醒。</view>
        </view>
        <text class="arrow">›</text>
      </view>
      <view class="action-item card" wx:if="{{canEnterAdmin}}" bindtap="goAdmin">
        <view>
          <view class="action-title">管理员维护</view>
          <view class="action-desc">维护知识库、模板、流程配置，查看操作日志。</view>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">隐私说明</view>
    <view class="privacy card">
      身份证号、手机号、生源地、户籍、休学与延毕等敏感信息不在学生端公开展示；老师和管理员查看敏感数据时应按权限控制并保留操作记录。
    </view>
  </view>
</view>
