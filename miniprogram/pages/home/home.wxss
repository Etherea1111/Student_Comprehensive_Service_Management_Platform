.hero {
  min-height: 360rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #1f2d46 0%, #1f5fbf 52%, #2d7d78 100%);
  color: #ffffff;
  overflow: hidden;
  position: relative;
}

.hero::after {
  position: absolute;
  right: -86rpx;
  bottom: -86rpx;
  width: 240rpx;
  height: 240rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  content: "";
}

.hero-content {
  padding: 34rpx 32rpx 32rpx;
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.eyebrow {
  display: inline-flex;
  min-height: 40rpx;
  padding: 0 14rpx;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 6rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.hero-status {
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 6rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  line-height: 40rpx;
}

.hero-title {
  margin-top: 28rpx;
  max-width: 720rpx;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-desc {
  margin-top: 16rpx;
  max-width: 700rpx;
  color: rgba(255, 255, 255, 0.86);
  line-height: 1.55;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.hero-meta text {
  margin-right: 14rpx;
  padding-right: 14rpx;
  border-right: 1rpx solid rgba(255, 255, 255, 0.35);
}

.hero-meta text:last-child {
  border-right: 0;
}

.hero-actions {
  display: flex;
  margin-top: 30rpx;
}

.hero-button {
  width: 184rpx;
  min-height: 70rpx;
  margin-right: 16rpx;
  padding: 0 18rpx;
  font-size: 26rpx;
}

.hero-button.ghost {
  border-color: rgba(255, 255, 255, 0.5);
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  box-shadow: none;
}

.module-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.module-card {
  width: 49%;
  min-height: 300rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
  position: relative;
}

.module-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.module-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.module-icon.qa {
  background: #1f5fbf;
}

.module-icon.process {
  background: #2d7d78;
}

.module-title {
  margin-top: 22rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.module-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.module-foot {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eaecf0;
  color: #475467;
  font-size: 23rpx;
}

.reminder {
  padding: 24rpx;
  border-left: 8rpx solid #f2a93b;
}

.reminder-head,
.reserved-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reminder-advisor {
  color: #667085;
  font-size: 24rpx;
}

.reminder-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.reminder-content {
  margin-top: 10rpx;
  color: #475467;
  line-height: 1.6;
}

.reserved-list {
  display: block;
}

.reserved-item {
  margin-bottom: 16rpx;
  padding: 22rpx;
  background: #fbfcfe;
}

.reserved-name {
  color: #101828;
  font-weight: 700;
}

.reserved-desc {
  margin-top: 12rpx;
  color: #667085;
  line-height: 1.55;
}

.reserved-api {
  margin-top: 12rpx;
  color: #475467;
  font-size: 22rpx;
  word-break: break-all;
}

@media (max-width: 520px) {
  .module-card {
    width: 100%;
  }

  .hero-actions {
    display: block;
  }

  .hero-button {
    width: 100%;
    margin-right: 0;
    margin-bottom: 14rpx;
  }
}
