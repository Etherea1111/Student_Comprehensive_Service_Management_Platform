.hero {
  min-height: 292rpx;
  border-radius: 8rpx;
  background: linear-gradient(135deg, #23395d 0%, #1f5fbf 58%, #2d7d78 100%);
  color: #ffffff;
  overflow: hidden;
}

.hero-content {
  padding: 34rpx 32rpx;
}

.eyebrow {
  display: inline-flex;
  min-height: 40rpx;
  padding: 0 14rpx;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.42);
  border-radius: 6rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-desc {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.86);
  line-height: 1.55;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.hero-meta text {
  margin-right: 14rpx;
  padding-right: 14rpx;
  border-right: 1rpx solid rgba(255, 255, 255, 0.35);
}

.hero-meta text:last-child {
  border-right: 0;
}

.module-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.module-card {
  width: 49%;
  min-height: 260rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.module-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.module-icon.qa {
  background: #1f5fbf;
}

.module-icon.process {
  background: #2d7d78;
}

.module-title {
  margin-top: 18rpx;
  color: #101828;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.module-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.55;
}

.reminder {
  padding: 24rpx;
}

.reminder-head,
.reserved-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reminder-advisor {
  color: #667085;
  font-size: 24rpx;
}

.reminder-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.reminder-content {
  margin-top: 10rpx;
  color: #475467;
  line-height: 1.6;
}

.reserved-list {
  display: block;
}

.reserved-item {
  margin-bottom: 16rpx;
  padding: 22rpx;
}

.reserved-name {
  color: #101828;
  font-weight: 700;
}

.reserved-desc {
  margin-top: 12rpx;
  color: #667085;
  line-height: 1.55;
}

.reserved-api {
  margin-top: 12rpx;
  color: #475467;
  font-size: 22rpx;
  word-break: break-all;
}

@media (max-width: 520px) {
  .module-card {
    width: 100%;
  }
}
