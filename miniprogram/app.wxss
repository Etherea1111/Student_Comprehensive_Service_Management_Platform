page {
  min-height: 100%;
  background: #f5f7fb;
  color: #1d2939;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  width: 100%;
  max-width: 960rpx;
  min-height: 100vh;
  margin: 0 auto;
  padding: 28rpx 28rpx 56rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #101828;
  line-height: 1.25;
}

.page-subtitle {
  margin-top: 10rpx;
  color: #667085;
  line-height: 1.55;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #101828;
}

.card {
  border: 1rpx solid #d0d5dd;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 24, 40, 0.05);
}

.muted {
  color: #667085;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 14rpx;
  border-radius: 6rpx;
  background: #eaf1ff;
  color: #1f5fbf;
  font-size: 22rpx;
  line-height: 40rpx;
}

.tag.warn {
  background: #fff4e5;
  color: #a15c00;
}

.tag.success {
  background: #e7f8ef;
  color: #067647;
}

.tag.neutral {
  background: #eef2f6;
  color: #475467;
}

.primary-button,
.secondary-button,
.text-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  margin: 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.2;
}

.primary-button {
  background: #1f5fbf;
  color: #ffffff;
}

.secondary-button {
  border: 1rpx solid #98a2b3;
  background: #ffffff;
  color: #344054;
}

.text-button {
  min-height: 56rpx;
  padding: 0 8rpx;
  background: transparent;
  color: #1f5fbf;
}

button::after {
  border: 0;
}

.empty {
  padding: 42rpx 28rpx;
  border: 1rpx dashed #98a2b3;
  border-radius: 8rpx;
  color: #667085;
  text-align: center;
  line-height: 1.6;
}

.divider {
  height: 1rpx;
  background: #eaecf0;
}
